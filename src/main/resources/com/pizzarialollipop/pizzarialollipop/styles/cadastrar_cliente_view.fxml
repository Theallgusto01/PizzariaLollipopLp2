<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pizzarialollipop.pizzarialollipop.pizzaria.model.ClienteController">
    <children>
        <VBox layoutX="50.0" layoutY="30.0" spacing="10">
            <children>
                <Label text="Cadastro de Clientes" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <HBox spacing="10">
                    <Label text="Nome:"/>
                    <TextField fx:id="txtNome" promptText="Nome do cliente"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="Telefone:"/>
                    <TextField fx:id="txtTelefone" promptText="Telefone do cliente"/>
                </HBox>

                <HBox spacing="10">
                    <Button text="Adicionar" onAction="#adicionarCliente"/>
                    <Button text="Atualizar" onAction="#atualizarCliente"/>
                    <Button text="Deletar" onAction="#deletarCliente"/>
                </HBox>

                <TableView fx:id="tabelaClientes" prefHeight="400.0" prefWidth="700.0">
                    <columns>
                        <TableColumn text="ID" fx:id="colId" prefWidth="50"/>
                        <TableColumn text="Nome" fx:id="colNome" prefWidth="300"/>
                        <TableColumn text="Telefone" fx:id="colTelefone" prefWidth="200"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
