<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pizzarialollipop.pizzarialollipop.pizzaria.model.ProdutoController">

    <!-- Título -->
    <top>
        <Label text="Gerenciamento de Produtos"
               style="-fx-font-size: 24px; -fx-padding: 10px;"
               BorderPane.alignment="CENTER"/>
    </top>

    <!-- Formulário de Cadastro -->
    <left>
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 20px;">
            <Label text="Nome do Produto:"/>
            <TextField fx:id="txtNome" promptText="Digite o nome do produto"/>

            <Label text="Preço:"/>
            <TextField fx:id="txtPreco" promptText="Digite o preço do produto"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Adicionar" onAction="#adicionarProduto"/>
                <Button text="Atualizar" onAction="#atualizarProduto"/>
                <Button text="Deletar" onAction="#deletarProduto"/>
            </HBox>
        </VBox>
    </left>

    <!-- Tabela de Produtos -->
    <center>
        <TableView fx:id="tabelaProdutos" prefWidth="600" prefHeight="400">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="100"/>
                <TableColumn fx:id="colNome" text="Nome" prefWidth="250"/>
                <TableColumn fx:id="colPreco" text="Preço" prefWidth="250"/>
            </columns>
        </TableView>
    </center>

    <!-- Rodapé -->
    <bottom>
        <Label text="© 2025 Pizzaria Lollipop - Todos os direitos reservados"
               style="-fx-font-size: 12px; -fx-padding: 10px;"
               BorderPane.alignment="CENTER"/>
    </bottom>
</BorderPane>
