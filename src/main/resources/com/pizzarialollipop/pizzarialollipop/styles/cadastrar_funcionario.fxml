<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.pizzarialollipop.pizzarialollipop.pizzaria.model.FuncionarioController">
    <children>
        <VBox spacing="10" alignment="CENTER">
            <Label text="Cadastro de Funcionário" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <HBox spacing="10">
                <Label text="Nome:" />
                <TextField fx:id="txtNome" promptText="Digite o nome" />
            </HBox>

            <HBox spacing="10">
                <Label text="Cargo:" />
                <TextField fx:id="txtCargo" promptText="Digite o cargo" />
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Adicionar" onAction="#adicionarFuncionario" />
                <Button text="Atualizar" onAction="#atualizarFuncionario" />
                <Button text="Deletar" onAction="#deletarFuncionario" />
            </HBox>

            <TableView fx:id="tabelaFuncionarios">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="150" />
                    <TableColumn fx:id="colCargo" text="Cargo" prefWidth="150" />
                </columns>
            </TableView>
        </VBox>
    </children>
</AnchorPane>
